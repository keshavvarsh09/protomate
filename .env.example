# ============ FRONTEND (vercel) ============
# safe to expose. these go in Vercel -> Project -> Settings -> Environment Variables.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# if you leave these blank, the app still runs on built-in mock data.

# ============ WORKER (gpu box only - NEVER commit) ============
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY   # full write access. keep local.
POLL_SECONDS=5

# provider keys live here, on the gpu box, never in the browser:
WAVESPEED_API_KEY=wsk_live_xxx
GROQ_API_KEY=gsk_xxx
GENAIPRO_API_KEY=
DASHSCOPE_API_KEY=
